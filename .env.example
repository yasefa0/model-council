# Model Council API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# OpenRouter API key — used for panel models (GPT, Gemini, Grok)
# Get yours at: https://openrouter.com/keys
OPENROUTER_API_KEY=sk-or-...

# Anthropic API key — used for the chairman model (Claude Opus)
# Get yours at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...